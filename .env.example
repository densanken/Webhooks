# 管理 API リクエストの X-Api-Key ヘッダーで受け付ける API キー (カンマ区切り)
API_KEYS=

# API ドキュメントへのアクセスに使用する Discord OAuth2 の認証情報
# https://discord.com/developers/applications でアプリケーションを作成してください
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# アクセスを許可する Discord ギルド (サーバー) の ID (カンマ区切り)
# ここに指定したギルドのメンバーのみ API ドキュメントにアクセスできます
# Interactions Bot のコマンド登録対象ギルド、guild webhook cache の同期対象も兼ねます
DISCORD_ALLOWED_GUILD_IDS=

# Discord Interactions Endpoint Bot 用の Application ID と公開鍵
# https://discord.com/developers/applications のアプリケーション設定から取得してください
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=

# Discord Bot トークン (Interactions Bot / guild webhook cache 同期に使用)
DISCORD_BOT_TOKEN=

# API ドキュメントのセッション Cookie の署名に使用するシークレット
# 生成コマンド: openssl rand -base64 32
DOC_SESSION_SECRET=

# 登録済み Webhook URL の構築に使用するパブリックオリジン (例: https://example.com)
# 空にすると相対 URL を返します
PUBLIC_BASE_URL=

# 有効な Webhook シークレット暗号化キーの識別子
WEBHOOK_SECRET_ENCRYPTION_KEY_ID=

# 保存された Webhook シークレットの暗号化に使用する Base64 エンコード済み 32 バイト AES-GCM キー
# 生成コマンド: openssl rand -base64 32
WEBHOOK_SECRET_ENCRYPTION_KEY=

# Deno KV データベースのファイルパス。空にするとデフォルトのデータベースを使用します
KV_PATH=

# ディスパッチャー cron が 1 回の実行で送信するキュー済みメッセージの最大件数
DISPATCH_MAX_MESSAGES_PER_RUN=50

# 1回の cron 実行内で Discord Webhook への送信間に挿入する遅延 (ミリ秒)
DISPATCH_INTERVAL_MS=1000

# キュー済みメッセージがデッドレターになるまでの最大配信試行回数
DISPATCH_MAX_ATTEMPTS=5

# デッドレター通知の送信先 Discord Webhook URL
# 設定すると、メッセージがデッドレターになるたびに通知が送信されます (レート制限時はキューに入ります)
DEAD_LETTER_NOTIFICATION_DISCORD_WEBHOOK_URL=
